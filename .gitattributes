# Cross-platform line ending settings for Kwaras
# Python files must use LF for interpreter compatibility

* text=auto

*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary